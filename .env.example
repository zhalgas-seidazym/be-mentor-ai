# ---- FastAPI ----
APP_NAME=MentorAI Platform
APP_ENV=development

# ---- Database ----
POSTGRES_DB=mentor_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
ALEMBIC_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Elastic Search ----
ELASTIC_SEARCH_HOST=http://elastic_search:9200

# ---- JWT ----
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ---- SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@example.com

# ---- OTP ----
OTP_TTL=300

# ---- OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
GOOGLE_DEEP_LINK_URI=mentoriai://oauth
OAUTH_STATE_TTL=600

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# ---- AirFlow ----
AIRFLOW_UID=50000
AIRFLOW_URL=http://airflow-api-server:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_API_AUTH_JWT_SECRET=your_secret

# ---- Parsing Variables ----
POSTGRES_CONN_ID=mentorai_db

HH_MAX_JOBS_PER_TARGET=120
HH_PER_PAGE=100
HH_MAX_PAGES=5
HH_ONLY_WITH_SALARY=false

MENTORAI_ENABLE_PARSER_SOURCE=false
PARSER_MAX_JOBS_PER_TARGET=40

MENTORAI_HH_USER_AGENT=MentorAI-AirflowBot/1.0 (email: your_email@example.com)